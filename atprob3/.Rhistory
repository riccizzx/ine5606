library(dplyr)
install.packages("dplyr")
library(dplyr)
library(dplyr)
library(ggplot2)
install.packages("ggplot2")
library(dplyr)
library(ggplot2)
# 1. LEITURA DOS DADOS
base = read.csv2("dados_alunos.csv")
set.seed(15032006)
base1 = base[sample(nrow(base), 90),]
# 2. MUDAR O NOME DAS VARIAVEIS SEXO E ESCOLA (1 = Masculino; 2 = Feminino) \
#                                          (1 = Publica;   2 = Particular)
base1$Sexo <- factor(base1$Sexo,
levels = c(1, 2),
labels = c("Masculino", "Feminino"))
base1$Escola <- factor(base1$Escola,
levels = c(1, 2),
labels = c("Publica", "Particular"))
# 3. CRIANDO A VARIAVEL IMC;
base1$imc <- base1$Peso / (base1$Altura^2)
# 4. CALCULANDO A MÉDIA, DESVIO PADRÃO E COEFICIENTE DE VARIAÇÃO PARA
#                                                   "IMC", "TR", "SB"
#  formula do desvio padrao:
cv <- function(x) {
sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)
}
# a) IMC por sexo:
base1 |>
group_by(Sexo) |>
summarise(
media = mean(imc, na.rm = TRUE),
desvio_padrao = sd(imc, na.rm = TRUE),
cv = cv(imc)
)
# b) TR por sexo:
base1 |>
group_by(Sexo) |>
summarise(
media = mean(TR, na.rm = TRUE),
desvio_padrao = sd(TR, na.rm = TRUE),
cv = cv(TR)
)
# c) SB por escola:
base1 |>
group_by(Escola) |>
summarise(
media = mean(SB, na.rm = TRUE),
desvio_padrao = sd(SB, na.rm = TRUE),
cv = cv(SB)
)
# 5. GRAFICO PARA MEDIR A VARIABILIDADE DOS ITENS 4a, 4b, 4c;
# IMC por sexo:
ggplot(base1, aes(x = imc, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição do IMC por Sexo")
# TR por sexo:
ggplot(base1, aes(x = TR, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da TR por Sexo")
# SB por escola:
ggplot(base1, aes(x = SB, fill = Escola)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da SB por Escola")
# IMC por sexo:
ggplot(base1, aes(x = Sexo, y = imc, fill = Sexo)) +
geom_boxplot() +
labs(title = "IMC por Sexo")
# TR por sexo:
ggplot(base1, aes(x = Sexo, y = TR, fill = Sexo)) +
geom_boxplot() +
labs(title = "TR por Sexo")
# SB por escola:
ggplot(base1, aes(x = Escola, y = SB, fill = Escola)) +
geom_boxplot() +
labs(title = "SB por Escola")
library(dplyr)
library(ggplot2)
# 1. LEITURA DOS DADOS
base <- read.csv2("dados_alunos.csv")
set.seed(15032006)
base1 <- base[sample(nrow(base), 90), ]
# 2. AJUSTE DAS VARIÁVEIS CATEGÓRICAS
base1$Sexo <- factor(
base1$Sexo,
levels = c(1, 2),
labels = c("Masculino", "Feminino")
)
base1$Escola <- factor(
base1$Escola,
levels = c(1, 2),
labels = c("Publica", "Particular")
)
# 3. CORREÇÃO DA ALTURA (caso esteja em cm)
if (mean(base1$Altura, na.rm = TRUE) > 10) {
base1$Altura <- base1$Altura / 100
}
# 4. CRIAÇÃO DO IMC
base1$imc <- base1$Peso / (base1$Altura^2)
# Função coeficiente de variação
cv <- function(x) {
sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)
}
# ==========================================================
# 4a) IMC por Sexo
res_imc <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(imc, na.rm = TRUE),
desvio_padrao = sd(imc, na.rm = TRUE),
cv = cv(imc)
)
print(res_imc)
# 4b) TR por Sexo
res_tr <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(TR, na.rm = TRUE),
desvio_padrao = sd(TR, na.rm = TRUE),
cv = cv(TR)
)
print(res_tr)
# 4c) SB por Escola
res_sb <- base1 |>
group_by(Escola) |>
summarise(
media = mean(SB, na.rm = TRUE),
desvio_padrao = sd(SB, na.rm = TRUE),
cv = cv(SB)
)
print(res_sb)
# IMC por sexo
ggplot(base1, aes(x = imc, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição do IMC por Sexo") +
theme_minimal()
# TR por sexo
ggplot(base1, aes(x = TR, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da TR por Sexo") +
theme_minimal()
# SB por escola
ggplot(base1, aes(x = SB, fill = Escola)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da SB por Escola") +
theme_minimal()
# IMC por sexo
ggplot(base1, aes(x = Sexo, y = imc, fill = Sexo)) +
geom_boxplot() +
labs(title = "IMC por Sexo") +
theme_minimal()
# TR por sexo
ggplot(base1, aes(x = Sexo, y = TR, fill = Sexo)) +
geom_boxplot() +
labs(title = "TR por Sexo") +
theme_minimal()
# SB por escola
ggplot(base1, aes(x = Escola, y = SB, fill = Escola)) +
geom_boxplot() +
labs(title = "SB por Escola") +
theme_minimal()
# ==========================================================
base1 <- base1 |>
filter(
!is.na(Altura),
Altura > 0,
!is.na(Peso)
)
# 4a) IMC por Sexo
res_imc <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(imc, na.rm = TRUE),
desvio_padrao = sd(imc, na.rm = TRUE),
cv = cv(imc)
)
print(res_imc)
# 4b) TR por Sexo
res_tr <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(TR, na.rm = TRUE),
desvio_padrao = sd(TR, na.rm = TRUE),
cv = cv(TR)
)
print(res_tr)
# 4c) SB por Escola
res_sb <- base1 |>
group_by(Escola) |>
summarise(
media = mean(SB, na.rm = TRUE),
desvio_padrao = sd(SB, na.rm = TRUE),
cv = cv(SB)
)
library(dplyr)
library(ggplot2)
# 1. LEITURA DOS DADOS
base <- read.csv2("dados_alunos.csv")
set.seed(15032006)
base1 <- base[sample(nrow(base), 90), ]
# 2. AJUSTE DAS VARIÁVEIS CATEGÓRICAS
base1$Sexo <- factor(
base1$Sexo,
levels = c(1, 2),
labels = c("Masculino", "Feminino")
)
base1$Escola <- factor(
base1$Escola,
levels = c(1, 2),
labels = c("Publica", "Particular")
)
# 3. CORREÇÃO DA ALTURA (caso esteja em cm)
if (mean(base1$Altura, na.rm = TRUE) > 10) {
base1$Altura <- base1$Altura / 100
}
# 4. CRIAÇÃO DO IMC
base1$imc <- base1$Peso / (base1$Altura^2)
# Função coeficiente de variação
cv <- function(x) {
sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)
}
# ==========================================================
base1 <- base1 |>
filter(
!is.na(Altura),
Altura > 0,
!is.na(Peso)
)
res_imc <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(imc, na.rm = TRUE),
desvio_padrao = sd(imc, na.rm = TRUE),
cv = cv(imc)
)
base1$imc <- base1$Peso / (base1$Altura^2)
base1 <- base1 |>
filter(!is.na(imc), is.finite(imc))
ggplot(base1, aes(x = imc, fill = Sexo)) +
geom_density(alpha = 0.5)
print(res_imc)
# 4b) TR por Sexo
res_tr <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(TR, na.rm = TRUE),
desvio_padrao = sd(TR, na.rm = TRUE),
cv = cv(TR)
)
print(res_tr)
# 4c) SB por Escola
res_sb <- base1 |>
group_by(Escola) |>
summarise(
media = mean(SB, na.rm = TRUE),
desvio_padrao = sd(SB, na.rm = TRUE),
cv = cv(SB)
)
print(res_sb)
# IMC por sexo
ggplot(base1, aes(x = imc, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição do IMC por Sexo") +
theme_minimal()
# TR por sexo
ggplot(base1, aes(x = TR, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da TR por Sexo") +
theme_minimal()
# SB por escola
ggplot(base1, aes(x = SB, fill = Escola)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da SB por Escola") +
theme_minimal()
library(dplyr)
library(ggplot2)
# 1. LEITURA DOS DADOS
base <- read.csv2("dados_alunos.csv")
set.seed(15032006)
base1 <- base[sample(nrow(base), 90), ]
base1 <- base1 |>
filter(
!is.na(Peso),
!is.na(Altura),
Altura > 0
)
base1$Sexo <- factor(
base1$Sexo,
levels = c(1, 2),
labels = c("Masculino", "Feminino")
)
base1$Escola <- factor(
base1$Escola,
levels = c(1, 2),
labels = c("Publica", "Particular")
)
if (mean(base1$Altura, na.rm = TRUE) > 10) {
base1$Altura <- base1$Altura / 100
}
base1$imc <- base1$Peso / (base1$Altura^2)
# Remover valores inválidos de IMC
base1 <- base1 |>
filter(is.finite(imc), !is.na(imc))
cv <- function(x) {
sd(x, na.rm = TRUE) / mean(x, na.rm = TRUE)
}
# IMC por sexo
res_imc <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(imc, na.rm = TRUE),
desvio_padrao = sd(imc, na.rm = TRUE),
cv = cv(imc)
)
print(res_imc)
# TR por sexo
res_tr <- base1 |>
group_by(Sexo) |>
summarise(
media = mean(TR, na.rm = TRUE),
desvio_padrao = sd(TR, na.rm = TRUE),
cv = cv(TR)
)
print(res_tr)
# SB por escola
res_sb <- base1 |>
group_by(Escola) |>
summarise(
media = mean(SB, na.rm = TRUE),
desvio_padrao = sd(SB, na.rm = TRUE),
cv = cv(SB)
)
print(res_sb)
# IMC por sexo
ggplot(base1, aes(x = imc, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição do IMC por Sexo") +
theme_minimal()
# TR por sexo
ggplot(base1, aes(x = TR, fill = Sexo)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da TR por Sexo") +
theme_minimal()
# SB por escola
ggplot(base1, aes(x = SB, fill = Escola)) +
geom_density(alpha = 0.5) +
labs(title = "Distribuição da SB por Escola") +
theme_minimal()
# IMC por sexo
ggplot(base1, aes(x = Sexo, y = imc, fill = Sexo)) +
geom_boxplot() +
labs(title = "IMC por Sexo") +
theme_minimal()
# TR por sexo
ggplot(base1, aes(x = Sexo, y = TR, fill = Sexo)) +
geom_boxplot() +
labs(title = "TR por Sexo") +
theme_minimal()
# SB por escola
ggplot(base1, aes(x = Escola, y = SB, fill = Escola)) +
geom_boxplot() +
labs(title = "SB por Escola") +
theme_minimal()
View(base1)
View(base1)
